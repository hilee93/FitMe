{
  "index" : {
    "max_ngram_diff" : 5
  },
  "analysis": {
    "tokenizer": {
      "feed_ngram_tokenizer": {
        "type": "ngram",
        "min_gram": 2,
        "max_gram": 7,
        "token_chars": ["letter", "digit"]
      }
    },
    "analyzer": {
      "feed_content_analyzer": {
        "char_filter": [],
        "tokenizer": "nori_tokenizer",
        "filter": [
          "nori_part_of_speech",
          "nori_readingform",
          "lowercase"
        ]
      },
      "feed_content_ngram_analyzer": {
        "type": "custom",
        "tokenizer": "feed_ngram_tokenizer",
        "filter": [
          "lowercase"
        ]
      }
    }
  }
}